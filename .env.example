# =============================================================================
# Network Synapse Quattro — Environment Variables
# =============================================================================
# Copy to .env and fill in values: cp .env.example .env

# Infrahub
INFRAHUB_URL=http://localhost:8000
INFRAHUB_TOKEN=06438eb2-8019-4776-878c-0941b1f1d1ec

# Temporal
TEMPORAL_ADDRESS=localhost:7233

# Nokia SR Linux (Containerlab)
SRLINUX_USER=admin
SRLINUX_PASS=NokiaSrl1!

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASS=infrahub

# Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Docker Compose port overrides (optional)
# NEO4J_PORT=7687
# REDIS_PORT=6379
# RABBITMQ_PORT=5672
# INFRAHUB_PORT=8000
# TEMPORAL_PORT=7233
# TEMPORAL_UI_PORT=8080

# =============================================================================
# Service URLs (quick reference — not consumed by code)
# =============================================================================
# Infrahub UI + API:      http://localhost:8000
# Infrahub GraphQL:       http://localhost:8000/graphql
# Temporal UI:            http://localhost:8080
# Neo4j Browser:          http://localhost:7474
# RabbitMQ Management:    http://localhost:15672
# Grafana:                http://localhost:3000
# Prometheus:             http://localhost:9090
# Containerlab Graph:     http://localhost:50080  (after lab deploy)
